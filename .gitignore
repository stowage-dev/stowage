# SvelteKit / Node
web/node_modules/
web/.svelte-kit/
web/build/
# The full SvelteKit static bundle is built by `make frontend`; only a
# tiny stub index.html is checked in so `go:embed all:dist` works on a
# clean clone.
/web/dist/*
!/web/dist/index.html

