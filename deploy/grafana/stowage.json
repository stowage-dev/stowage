{
  "title": "Stowage",
  "uid": "stowage-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["stowage", "s3"],
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0
      },
      {
        "name": "backend",
        "label": "Backend",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(stowage_requests_total, backend)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by status class",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum(rate(stowage_requests_total{backend=~\"$backend\"}[1m])) by (status_class)",
          "legendFormat": "{{status_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request duration p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 1 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(stowage_request_duration_seconds_bucket{backend=~\"$backend\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(stowage_request_duration_seconds_bucket{backend=~\"$backend\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(stowage_request_duration_seconds_bucket{backend=~\"$backend\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Response bytes per second",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum(rate(stowage_response_bytes_sum{backend=~\"$backend\"}[1m])) by (backend)",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "5xx in last 5 minutes",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(stowage_requests_total{status_class=\"5xx\",backend=~\"$backend\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "SQLite DB size",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        { "expr": "stowage_sqlite_db_bytes", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Process memory + goroutines",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 0 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rss" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "goroutines" },
            "properties": [{ "id": "unit", "value": "short" }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "rss", "refId": "A" },
        { "expr": "go_goroutines", "legendFormat": "goroutines", "refId": "B" }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top backends by request rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "options": { "showHeader": true },
      "targets": [
        {
          "expr": "topk(10, sum(rate(stowage_requests_total[5m])) by (backend))",
          "legendFormat": "{{backend}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
